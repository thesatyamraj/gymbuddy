# ============================================================
# SERVER — PRODUCTION ENVIRONMENT (set these in Render dashboard)
# Do NOT commit real values. This file is a template only.
# ============================================================

NODE_ENV=production
# PORT is provided automatically by Render — do not hardcode it.

# --- Database (MongoDB Atlas) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gymbuddy?retryWrites=true&w=majority

# --- JWT secrets (GENERATE NEW ONES — see DEPLOYMENT.md) ---
JWT_ACCESS_SECRET=<long_random_string_1>
JWT_REFRESH_SECRET=<long_random_string_2>

# --- Allowed front-end origins (CORS) ---
# Your deployed Vercel URL (no trailing slash):
CLIENT_WEB_URL=https://your-app.vercel.app
# Optional: only needed if a mobile web build calls the API from a browser origin
CLIENT_MOBILE_URL=https://your-app.vercel.app

# --- Cloudinary (image uploads) ---
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# --- Email / SMTP (OTP verification via nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your_email@gmail.com>
SMTP_PASS=<your_16_char_gmail_app_password>
SMTP_FROM=<your_email@gmail.com>

# AI Coach (Groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=openai/gpt-oss-20b
